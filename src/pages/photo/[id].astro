---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import TextPhotoSplit from '../../components/photo-templates/TextPhotoSplit.astro'
import StackedDetails from '../../components/photo-templates/StackedDetails.astro'
import PhotoTop from '../../components/photo-templates/PhotoTop.astro'

export async function getStaticPaths() {
  const photos = await getCollection('photos')
  return photos.map((photo) => ({
    params: { id: photo.data.id },
    props: { photo },
  }))
}

const { photo } = Astro.props

const templates = {
  'text-left': { Component: TextPhotoSplit, props: { textSide: 'left', ratio: 'half' } },
  'text-right': { Component: TextPhotoSplit, props: { textSide: 'right', ratio: 'half' } },
  'text-left-third': { Component: TextPhotoSplit, props: { textSide: 'left', ratio: 'third' } },
  'text-right-third': { Component: TextPhotoSplit, props: { textSide: 'right', ratio: 'third' } },
  stacked: { Component: StackedDetails, props: {} },
  'photo-top': { Component: PhotoTop, props: {} },
} as const

const { Component, props } = templates[photo.data.template]
---

<Layout title={photo.data.title}>
  <Header />
  <Component photo={photo} {...props} />
</Layout>
