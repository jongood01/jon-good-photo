---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import Button from '../Button.astro'
import { getPhotoWidths } from '../../utils/photoImage'

interface Props {
  photo: CollectionEntry<'photos'>
  textSide?: 'left' | 'right'
  ratio?: 'half' | 'third'
}

const { photo, textSide = 'left', ratio = 'half' } = Astro.props
const { data } = photo

const gridColsClass = ratio === 'third' ? 'lg:grid-cols-3' : 'lg:grid-cols-2'
const textSpanClass = ratio === 'third' ? 'lg:col-span-1' : ''
const photoSpanClass = ratio === 'third' ? 'lg:col-span-2' : ''
const textOrderClass = textSide === 'right' ? 'lg:order-2' : 'lg:order-1'
const photoOrderClass = textSide === 'right' ? 'lg:order-1' : 'lg:order-2'
---

<main class={`min-h-screen bg-stone-50 grid grid-cols-1 ${gridColsClass}`}>
  <div class={`flex items-center justify-center px-6 lg:px-16 pt-[140px] pb-24 lg:pb-20 ${textSpanClass} ${textOrderClass}`}>
    <div class="max-w-md">
      <h1 class="font-semibold mb-2">{data.title}</h1>
      {data.location && <p class="text-sm text-gray-500 mb-6">{data.location}</p>}
      <p class="text-lg text-gray-600 mb-6 whitespace-pre-wrap">{data.description}</p>

      <div class="flex space-x-8 text-sm text-gray-500">
        <div><span class="font-medium">Format:</span> {data.format}</div>
        <div><span class="font-medium">Aspect Ratio:</span> {data.aspectRatio}</div>
      </div>

      <div class="mt-4 text-xs text-gray-400">
        Collection {data.collectionIndex} • Category {data.categoryIndex} • Image {data.imageIndex}
      </div>

      <div class="mt-12 flex flex-col sm:flex-row gap-4">
        <Button href={`/contact?photo=${data.id}`}>Enquire</Button>
        <Button href={`/?selected=${data.id}#gallery`} variant="outline"> Back to gallery →</Button>
      </div>
    </div>
  </div>

  <div class={`flex items-center justify-center px-6 lg:px-16 pt-[140px] pb-10 lg:pb-20 ${photoSpanClass} ${photoOrderClass}`}>
    <Image
      src={data.file}
      alt={data.altText}
      widths={getPhotoWidths(data.aspectRatio)}
      sizes={ratio === 'third' ? '(max-width: 1024px) 100vw, 66vw' : '(max-width: 1024px) 100vw, 50vw'}
      quality={'high'}
      class="w-full h-auto max-h-[70vh] object-contain"
    />
  </div>
</main>
