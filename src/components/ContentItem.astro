---
interface Props {
  count: string;
  label: string;
  page: string;
}

const { count, label, page } = Astro.props;
---

<li class="flex items-baseline gap-3">
  <span class="italic text-black/60 w-6 shrink-0">{count}</span>
  <span>{label}</span>
  <span class="flex-1 border-b border-dotted border-black/30 translate-y-[-4px]"></span>
  <span class="text-sm text-black/60">{page}</span>
</li>
